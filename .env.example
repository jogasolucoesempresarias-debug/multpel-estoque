# Painel de Estoque — variáveis (copie para .env e preencha)

# Sessão / acesso
SECRET_KEY=troque-por-secrets.token_hex(32)
ESTOQUE_SENHA=defina-uma-senha            # vazio = sem login (só dev local)
PORT=5001

# Postgres (orçamento + planos de ação)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=estoque_db
DB_USER=estoque
DB_PASSWORD=

# Power BI (Service Principal) — mesmas credenciais do Multpel
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_GROUP_ID=
# datasets já têm default no código; sobrescreva só se mudar
POWERBI_DATASET_ID_ESTOQUE=32fb60e1-5ff1-47ae-9472-b7ce7049f2ce
POWERBI_DATASET_ID_RCA=f2fbf288-611a-4b17-aeb3-a6f77ef04e3b
